/ {
	zephyr,user {
		timestamp = <&ctimer0>;
	};
};

&ctimer0 {
	prescale = <95>;
};

&zephyr_udc0 {
	gs_usb0: gs_usb0 {
		compatible = "zephyr,gs_usb";
	};
};

&can0 {
	bosch,mram-cfg = <0x0 1 1 64 64 0 10 10>;
};
