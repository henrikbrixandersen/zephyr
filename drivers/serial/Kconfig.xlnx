config UART_XLNX_PS
	bool "Xilinx serial driver for MPSoC"
	depends on (SOC_XILINX_ZYNQ_7000 || SOC_XILINX_ZYNQMP)
	select SERIAL_HAS_DRIVER
	help
	  This option enables the UART driver for Xilinx Zynq 7000 and
	  MPSoC platforms.
